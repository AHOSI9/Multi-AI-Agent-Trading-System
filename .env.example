# Runtime
TRADING_ENV=paper
FEED_MODE=simulated
EXECUTION_MODE=paper
LIVE_TRADING_CONFIRM=false
STATE_DB_PATH=runtime/trading_state.sqlite

# Markets
SYMBOLS=BTC/USDT:crypto,EURUSD:forex,XAUUSD:gold

# Risk
ACCOUNT_EQUITY=10000
RISK_PER_TRADE=0.005
MAX_DAILY_LOSS_PCT=0.03
MAX_SYMBOL_EXPOSURE_PCT=0.20
MAX_TOTAL_EXPOSURE_PCT=0.60
MIN_CONFIDENCE=0.62

# Optional crypto execution/feed
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=

# Optional MT5 feed/execution
MT5_PATH=
MT5_PORTABLE=false
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
